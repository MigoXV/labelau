{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "noEmit": false,
    "outDir": "dist-node",
    "types": ["node"],
    "jsx": "react-jsx"
  },
  "include": ["src/shared", "src/host-core", "src/host-service", "src/electron"],
  "exclude": ["src/**/*.test.ts"]
}
